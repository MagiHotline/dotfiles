#Font
# font_family FiraCode
# italic_font auto
# bold_italic_font auto
font_size 16.0

# Theme
# foreground #f8f8f2
# background #000000
# url_color #d65c9d

# Cursor
# cursor #8fee96
cursor_trail 3
cursor_trail_start_threshold 0

# Background Blur & Opacity
background_blur 8
background_opacity 0.80

hide_window_decoration yes

# Kitty Mod
kitty_mod cmd+shift


# Tab Bar
tab_bar_min_tabs            2
tab_bar_edge                bottom
tab_bar_style               powerline
tab_powerline_style         angled
tab_title_template          {title}{' :{}:'.format(num_windows) if num_windows > 1 else ''}

#: Window management {{{

map kitty_mod+j next_window
map kitty_mod+k previous_window

#: }}}

term xterm-256color
include dracula.conf

# BEGIN_KITTY_FONTS
font_family      family=Menlo postscript_name=Menlo-Regular
bold_font        auto
italic_font      auto
bold_italic_font auto
# END_KITTY_FONTS

# BEGIN_KITTY_THEME
# Tokyo Night Storm
include current-theme.conf
# END_KITTY_THEME
